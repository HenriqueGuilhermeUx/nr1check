{
  "name": "nr1check",
  "version": "1.0.0",
  "private": true,
  "description": "NR1Check — Plataforma de compliance psicossocial NR-1 para PMEs brasileiras",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @nr1check/db generate",
    "db:migrate": "pnpm --filter @nr1check/db migrate",
    "db:push": "pnpm --filter @nr1check/db push",
    "db:seed": "pnpm --filter @nr1check/db seed",
    "db:studio": "pnpm --filter @nr1check/db studio"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
