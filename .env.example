# =========================================
# NR1Check Essencial — Environment Variables
# Copie para .env e preencha apenas o necessário
# =========================================

# --- App ---
NODE_ENV=development
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:3000

# --- Supabase / Postgres ---
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.SEU_PROJETO.supabase.co:5432/postgres
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=eyJxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# Frontend
VITE_API_BASE_URL=http://localhost:3000
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxx

# --- OpenAI opcional ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# =========================================
# LEGADO TEMPORÁRIO
# A versão atual do código ainda pode pedir essas variáveis.
# Vamos remover em fases: Clerk -> Supabase Auth, Stripe -> Woovi, R2 -> Supabase Storage/HTML.
# =========================================

# Clerk temporário
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Stripe temporário — será substituído por Woovi Pix
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Cloudflare R2 temporário — evitar usar no MVP
R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET=nr1check-documents
R2_PUBLIC_URL=https://example.com
R2_ENDPOINT=https://example.com

# Z-API opcional — deixar para depois
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# Produção
RENDER_EXTERNAL_URL=https://nr1check-api.onrender.com
NETLIFY_URL=https://nr1check.com.br
