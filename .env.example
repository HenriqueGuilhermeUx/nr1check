# =========================================
# NR1Check — Environment Variables
# Copie este arquivo para .env e preencha
# =========================================

# --- App ---
NODE_ENV=development
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:3000

# --- Supabase (Postgres) ---
# Pegue em https://app.supabase.com → Settings → Database
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.SEU_PROJETO.supabase.co:5432/postgres
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.SEU_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.SEU_SERVICE_ROLE_KEY

# --- Clerk (Auth) ---
# Pegue em https://dashboard.clerk.com → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx
# Frontend (Vite)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# --- Cloudflare R2 (Storage) ---
# Pegue em https://dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=seu_account_id
R2_ACCESS_KEY_ID=seu_access_key
R2_SECRET_ACCESS_KEY=seu_secret_key
R2_BUCKET=nr1check-documents
R2_PUBLIC_URL=https://pub-xxx.r2.dev
R2_ENDPOINT=https://account_id.r2.cloudflarestorage.com

# --- Stripe (Pagamentos) ---
# Pegue em https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Frontend (Vite)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- Z-API (WhatsApp) ---
# Pegue em https://www.z-api.io → Instâncias
ZAPI_INSTANCE_ID=xxx
ZAPI_TOKEN=xxx
ZAPI_CLIENT_TOKEN=xxx

# --- OpenAI (LLM para geração de PGR/Ordens de Serviço) ---
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini

# --- Render / Netlify (Produção) ---
# Preencher apenas em produção, com as URLs reais
RENDER_EXTERNAL_URL=https://nr1check-api.onrender.com
NETLIFY_URL=https://nr1check.com.br
